#!/bin/sh
# commit-msg — บังคับ "type: description" ห้าม @ prefix
# แก้ type list ได้ที่ gwork.json → commit.types (ไม่ต้องแตะไฟล์นี้)
MSG=$(head -1 "$1")
case "$MSG" in
  @*) echo "commit-msg: ห้ามขึ้นต้นด้วย @ — ใช้ type: description" >&2; exit 1 ;;
esac
# ปล่อยข้อความที่ git สร้างเอง (merge/revert/fixup/squash) — บังคับ format ไม่ได้
case "$MSG" in
  "Merge "*|"Revert "*|"fixup! "*|"squash! "*) exit 0 ;;
esac
DEFAULT_TYPES='feat|fix|chore|refactor|docs|test|perf|style|ci'
# ไม่มี gwork.json = default · มีแต่ parse ไม่ได้ = block (config เสียห้ามเงียบ)
TYPES=$(node -p "(()=>{try{const c=require(process.cwd()+'/gwork.json');const t=c.commit&&c.commit.types;return Array.isArray(t)&&t.length?t.join('|'):''}catch(e){return e.code==='MODULE_NOT_FOUND'?'':'__BAD__'}})()" 2>/dev/null)
if [ "$TYPES" = "__BAD__" ]; then
  echo "commit-msg: gwork.json parse ไม่ได้ — แก้ config ก่อน commit" >&2; exit 1
fi
[ -z "$TYPES" ] && TYPES="$DEFAULT_TYPES"
echo "$MSG" | grep -qE "^($TYPES)(\([^)]+\))?: .+" || {
  echo "commit-msg: format ต้องเป็น 'type: description' (type: $TYPES)" >&2
  exit 1
}
